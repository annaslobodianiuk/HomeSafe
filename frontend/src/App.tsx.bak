        <span>РќР°РґС–Р№РЅС–СЃС‚СЊ {apartment.trustScore}/100</span>
        <span>Р’РёРіС–РґРЅС–СЃС‚СЊ {apartment.valueScore}/100</span>
      </div>
      <p className="review-card-description">{shortText(apartment.description, 220)}</p>
    </article>
  );
}

function ApartmentDetailPage({
  apartment,
  mode,
  isFavorite,
  onBack,
  onFavorite,
  onReviewStatus
}: {
  apartment: Apartment;
  mode: "catalog" | "review";
  isFavorite: boolean;
  onBack: () => void;
  onFavorite?: (apartment: Apartment) => void;
  onReviewStatus?: (apartmentId: string, status: string) => Promise<void>;
}) {
  const gallery = apartmentGallery(apartment);
  const [activeImage, setActiveImage] = useState(gallery[0]);
  const chartData = apartment.priceHistory?.map((item) => ({
    month: new Date(item.recordedAt).toLocaleDateString("uk-UA", { month: "short" }),
    price: item.price
  })) || [];

  useEffect(() => {
    setActiveImage(gallery[0]);
  }, [apartment.id]);

  return (
    <main className="detail-page">
      <div className="detail-page-head">
        <button className="secondary-button" onClick={onBack}><ArrowLeft size={18} /> РќР°Р·Р°Рґ</button>
        <div className="detail-page-actions">
          {mode === "catalog" && onFavorite && (
            <button className="primary-button compact" onClick={() => onFavorite(apartment)}>
              <Heart size={18} fill={isFavorite ? "currentColor" : "none"} />
              {isFavorite ? "Р’ РѕР±СЂР°РЅРѕРјСѓ" : "Р”РѕРґР°С‚Рё РІ РѕР±СЂР°РЅРµ"}
            </button>
          )}
          {mode === "review" && onReviewStatus && (
            <>
              <button className="approve-button wide" onClick={() => void onReviewStatus(apartment.id, "PUBLISHED")}><Check size={18} /> РћРїСѓР±Р»С–РєСѓРІР°С‚Рё</button>
              <button className="reject-button wide" onClick={() => void onReviewStatus(apartment.id, "REJECTED")}><X size={18} /> Р’С–РґС…РёР»РёС‚Рё</button>
            </>
          )}
        </div>
      </div>

      <section className="detail-layout">
        <div className="detail-main">
          <div className="detail-hero-image">
            <img src={activeImage} alt={apartment.title} />
          </div>
          {gallery.length > 1 && (
            <div className="detail-gallery-strip">
              {gallery.map((image) => (
                <button
                  key={image}
                  className={`detail-thumb ${image === activeImage ? "active" : ""}`}
                  onClick={() => setActiveImage(image)}
                >
                  <img src={image} alt={apartment.title} />
                </button>
              ))}
            </div>
          )}
          <article className="detail-description-card">
            <span className="eyebrow">{mode === "review" ? "РњРѕРґРµСЂР°С†С–СЏ РѕРіРѕР»РѕС€РµРЅРЅСЏ" : "РџРѕРІРЅРёР№ РѕРїРёСЃ РєРІР°СЂС‚РёСЂРё"}</span>
            <h1>{apartment.title}</h1>
            <p className="detail-location"><MapPin size={16} />{apartment.city}, {apartment.district} вЂў {apartment.address}</p>
            <div className="detail-meta-row">
              <span>{apartment.rooms} РєС–РјРЅ.</span>
              <span>{apartment.area} Рј2</span>
              <span>{apartment.floor}/{apartment.totalFloors} РїРѕРІРµСЂС…</span>
              <span>{apartment.ownerType}</span>
            </div>
            <div className="score-grid detail-score-grid">
              <ScoreBadge label="РќР°РґС–Р№РЅС–СЃС‚СЊ" value={apartment.trustScore} description="РїРµСЂРµРІС–СЂРєР° РѕРіРѕР»РѕС€РµРЅРЅСЏ" tone="green" />
              <ScoreBadge label="Р’РёРіС–РґРЅС–СЃС‚СЊ" value={apartment.valueScore} description="РїРѕСЂС–РІРЅСЏРЅРЅСЏ С†С–РЅРё" tone="blue" />
              <ScoreBadge label="РљРѕРјС„РѕСЂС‚" value={apartment.comfortScore} description="СѓРјРѕРІРё СЂР°Р№РѕРЅСѓ" tone="amber" />
            </div>
            <div className="detail-price-line">
              <strong>{formatPrice(apartment.price, apartment.currency)}</strong>
              <span>СЂРёРЅРєРѕРІР° С†С–РЅР°: {formatPrice(apartment.marketAveragePrice, apartment.currency)}</span>
            </div>
            <p className="detail-full-description">{apartment.description || "РћРїРёСЃ РІС–РґСЃСѓС‚РЅС–Р№"}</p>
          </article>
        </div>

        <aside className="detail-sidebar">
          <div className="recommendation-box">
            <strong>Р§РѕРјСѓ СЃРёСЃС‚РµРјР° СЂРµРєРѕРјРµРЅРґСѓС” С†СЋ РєРІР°СЂС‚РёСЂСѓ:</strong>
            <ul>
              {apartment.recommendationReasons.map((reason) => (
                <li key={reason}><CheckCircle2 size={16} />{reason}</li>
              ))}
