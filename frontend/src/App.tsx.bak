              <AreaChart data={chartData}>
                <CartesianGrid stroke="#e5ebf4" strokeDasharray="3 3" />
                <XAxis dataKey="month" tickLine={false} axisLine={false} />
                <YAxis tickLine={false} axisLine={false} width={48} />
                <Tooltip formatter={(value) => `${currency.format(Number(value))} РіСЂРЅ`} />
                <Area type="monotone" dataKey="price" stroke="#1769e0" strokeWidth={3} fill="#dceaff" />
              </AreaChart>
            </ResponsiveContainer>
          </div>
          <div className="infrastructure-grid detail-infrastructure-grid">
            <div><span>РЁРєРѕР»Р°</span><strong>{apartment.infrastructure?.schoolDistanceMeters ?? "-"} Рј</strong></div>
            <div><span>Р›С–РєР°СЂРЅСЏ</span><strong>{apartment.infrastructure?.hospitalDistanceMeters ?? "-"} Рј</strong></div>
            <div><span>РўСЂР°РЅСЃРїРѕСЂС‚</span><strong>{apartment.infrastructure?.transportDistanceMeters ?? "-"} Рј</strong></div>
            <div><span>РЎСѓРїРµСЂРјР°СЂРєРµС‚</span><strong>{apartment.infrastructure?.supermarketDistanceMeters ?? "-"} Рј</strong></div>
          </div>
        </aside>
      </section>
    </main>
  );
}

function PendingAccount({ user, onLogout }: { user: UserSummary; onLogout: () => Promise<void> }) {
  return (
    <main className="account-page">
      <section className="status-panel">
        <Clock3 size={42} />
        <span className="eyebrow">РћР±Р»С–РєРѕРІРёР№ Р·Р°РїРёСЃ СЃС‚РІРѕСЂРµРЅРѕ</span>
        <h1>Р’С–С‚Р°С”РјРѕ, {user.name}</h1>
        <p>Р’Р°С€ РїСЂРѕС„С–Р»СЊ РѕС‡С–РєСѓС” СЃС…РІР°Р»РµРЅРЅСЏ Р°РґРјС–РЅС–СЃС‚СЂР°С‚РѕСЂР°. РџС–СЃР»СЏ СЃС…РІР°Р»РµРЅРЅСЏ РІРё Р·РјРѕР¶РµС‚Рµ РґРѕРґР°РІР°С‚Рё РєРІР°СЂС‚РёСЂРё РІ РѕР±СЂР°РЅРµ С‚Р° РєРѕСЂРёСЃС‚СѓРІР°С‚РёСЃСЏ РєР°Р±С–РЅРµС‚РѕРј.</p>
        <button className="secondary-button" onClick={onLogout}><LogOut size={18} /> Р’РёР№С‚Рё</button>
      </section>
    </main>
  );
}

function FavoritesPage({ favorites, onSelect, onRemove }: { favorites: Apartment[]; onSelect: (apartment: Apartment) => void; onRemove: (apartment: Apartment) => void }) {
  return (
    <main className="page-section">
      <div className="section-heading">
        <div><span className="eyebrow">РћСЃРѕР±РёСЃС‚РёР№ РєР°Р±С–РЅРµС‚</span><h1>РћР±СЂР°РЅС– РєРІР°СЂС‚РёСЂРё</h1></div>
        <div className="trust-summary"><span>Р—Р±РµСЂРµР¶РµРЅРѕ</span><strong>{favorites.length}</strong></div>
      </div>
      {favorites.length === 0 ? (
        <div className="empty-state">
          <Heart size={38} />
          <h2>Р’ РѕР±СЂР°РЅРѕРјСѓ РїРѕРєРё РїРѕСЂРѕР¶РЅСЊРѕ</h2>
          <p>Р”РѕРґР°РІР°Р№С‚Рµ РєРІР°СЂС‚РёСЂРё СЃРµСЂС†РµРј РЅР° СЃС‚РѕСЂС–РЅС†С– РїРѕС€СѓРєСѓ.</p>
        </div>
      ) : (
        <div className="favorites-grid">
          {favorites.map((apartment) => (
            <ApartmentCard key={apartment.id} apartment={apartment} selected={false} onSelect={onSelect} isFavorite onFavorite={() => onRemove(apartment)} />
          ))}
        </div>
      )}
    </main>
  );
}

function UserAccount({ user, favorites }: { user: UserSummary; favorites: Apartment[] }) {
  return (
    <main className="page-section">
      <div className="profile-header">
        <div className="profile-avatar"><UserRound size={34} /></div>
        <div><span className="eyebrow">РљР°Р±С–РЅРµС‚ РєРѕСЂРёСЃС‚СѓРІР°С‡Р°</span><h1>{user.name}</h1><p>{user.email}</p></div>
        <span className="approved-badge"><Check size={16} /> РЎС…РІР°Р»РµРЅРѕ</span>
      </div>
      <div className="dashboard-grid account-stats">
        <article><Heart size={21} /><strong>{favorites.length}</strong><span>РѕР±СЂР°РЅРёС… РєРІР°СЂС‚РёСЂ</span></article>
        <article><Bell size={21} /><strong>0</strong><span>РЅРѕРІРёС… СЃРїРѕРІС–С‰РµРЅСЊ</span></article>
        <article><Search size={21} /><strong>0</strong><span>Р·Р±РµСЂРµР¶РµРЅРёС… РїРѕС€СѓРєС–РІ</span></article>
        <article><ShieldCheck size={21} /><strong>100%</strong><span>РїСЂРѕС„С–Р»СЊ РїС–РґС‚РІРµСЂРґР¶РµРЅРѕ</span></article>
      </div>
    </main>
  );
}

function AdminConsolePage({
  users,
  sources,
  imports,
  reviewListings,
  tab,
  onTabChange,
  onStatusChange,
  onSourceToggle,
  onRunSync,
  onReviewStatus,
  onOpenReview
}: {
  users: UserSummary[];
  sources: DataSource[];
  imports: ImportRun[];
  reviewListings: Apartment[];
  tab: "users" | "sources" | "review";
  onTabChange: (tab: "users" | "sources" | "review") => void;
  onStatusChange: (userId: string, status: string) => Promise<void>;
  onSourceToggle: (source: DataSource) => Promise<void>;
  onRunSync: (code: string) => Promise<void>;
  onReviewStatus: (apartmentId: string, status: string) => Promise<void>;
  onOpenReview: (apartment: Apartment) => void;
}) {
  const pending = users.filter((item) => item.status === "PENDING").length;
  const approved = users.filter((item) => item.status === "APPROVED").length;
  const activeSources = sources.filter((item) => item.enabled).length;

  return (
    <main className="page-section">
      <div className="section-heading">
        <div><span className="eyebrow">РљР°Р±С–РЅРµС‚ Р°РґРјС–РЅС–СЃС‚СЂР°С‚РѕСЂР°</span><h1>РљРµСЂСѓРІР°РЅРЅСЏ РєРѕСЂРёСЃС‚СѓРІР°С‡Р°РјРё С‚Р° С–РјРїРѕСЂС‚РѕРј</h1></div>
        <div className="trust-summary"><span>РћРіРѕР»РѕС€РµРЅСЊ РЅР° РјРѕРґРµСЂР°С†С–С—</span><strong>{reviewListings.length}</strong></div>
      </div>
      <div className="admin-summary">
        <StatCard icon={UsersRound} label="РІСЃСЊРѕРіРѕ РєРѕСЂРёСЃС‚СѓРІР°С‡С–РІ" value={users.length} />
        <StatCard icon={Clock3} label="РѕС‡С–РєСѓСЋС‚СЊ СЃС…РІР°Р»РµРЅРЅСЏ" value={pending} />
        <StatCard icon={ShieldCheck} label="СЃС…РІР°Р»РµРЅРѕ" value={approved} />
        <StatCard icon={Database} label="Р°РєС‚РёРІРЅРёС… РґР¶РµСЂРµР»" value={activeSources} />
      </div>
      <div className="admin-tabs">
        <button className={tab === "users" ? "active" : ""} onClick={() => onTabChange("users")}>РљРѕСЂРёСЃС‚СѓРІР°С‡С–</button>
        <button className={tab === "sources" ? "active" : ""} onClick={() => onTabChange("sources")}>Р”Р¶РµСЂРµР»Р°</button>
        <button className={tab === "review" ? "active" : ""} onClick={() => onTabChange("review")}>РњРѕРґРµСЂР°С†С–СЏ</button>
      </div>
      {tab === "users" && (
        <div className="users-table">
          <div className="users-table-head"><span>РљРѕСЂРёСЃС‚СѓРІР°С‡</span><span>Р”Р°С‚Р° СЂРµС”СЃС‚СЂР°С†С–С—</span><span>РЎС‚Р°С‚СѓСЃ</span><span>Р”С–С—</span></div>
          {users.map((item) => (
            <div className="user-row" key={item.id}>
              <div><strong>{item.name}</strong><span>{item.email}</span></div>
              <span>{new Date(item.createdAt).toLocaleDateString("uk-UA")}</span>
              <span className={`status-badge ${item.status.toLowerCase()}`}>{item.status === "PENDING" ? "РћС‡С–РєСѓС”" : item.status === "APPROVED" ? "РЎС…РІР°Р»РµРЅРѕ" : "Р’С–РґС…РёР»РµРЅРѕ"}</span>
              <div className="row-actions">
                <button className="approve-button" onClick={() => void onStatusChange(item.id, "APPROVED")} aria-label="РЎС…РІР°Р»РёС‚Рё"><Check size={18} /></button>
                <button className="reject-button" onClick={() => void onStatusChange(item.id, "REJECTED")} aria-label="Р’С–РґС…РёР»РёС‚Рё"><X size={18} /></button>
              </div>
            </div>
          ))}
        </div>
      )}
      {tab === "sources" && (
        <div className="admin-stack">
          <div className="source-grid">
            {sources.map((source) => (
              <article className="source-card" key={source.code}>
                <div className="source-card-head">
                  <div><strong>{source.name}</strong><span>{source.code}</span></div>
                  <span className={`status-badge ${source.enabled ? "approved" : "pending"}`}>{source.enabled ? "РђРєС‚РёРІРЅРµ" : "Р’РёРјРєРЅРµРЅРµ"}</span>
                </div>
                <p>{source.baseUrl}</p>
                <div className="source-meta">
                  <span>РљР»СЋС‡: {source.hasApiKey ? "РїС–РґРєР»СЋС‡РµРЅРѕ" : "РІС–РґСЃСѓС‚РЅС–Р№"}</span>
                  <span>РќР°РґС–Р№РЅС–СЃС‚СЊ: {source.reliability}/100</span>
                  <span>РћСЃС‚Р°РЅРЅС–Р№ СЃС‚Р°С‚СѓСЃ: {source.lastStatus || "С‰Рµ РЅРµ Р±СѓР»Рѕ"}</span>
                </div>
                {source.lastError && <p className="source-error">{source.lastError}</p>}
                <div className="source-actions">
                  <button className="secondary-button" onClick={() => void onSourceToggle(source)}>{source.enabled ? "Р’РёРјРєРЅСѓС‚Рё" : "РЈРІС–РјРєРЅСѓС‚Рё"}</button>
                  <button className="primary-button compact" onClick={() => void onRunSync(source.code)}><RefreshCw size={16} /> РЎРёРЅС…СЂРѕРЅС–Р·СѓРІР°С‚Рё</button>
                </div>
              </article>
            ))}
          </div>
          <div className="users-table import-table">
            <div className="users-table-head"><span>Р”Р¶РµСЂРµР»Рѕ</span><span>РџРѕС‡Р°С‚РѕРє</span><span>Р РµР·СѓР»СЊС‚Р°С‚</span><span>РџС–РґСЃСѓРјРѕРє</span></div>
            {imports.map((item) => (
              <div className="user-row" key={item.id}>
                <div><strong>{item.dataSource?.name || item.dataSource?.code}</strong><span>{item.requestedCity || "РІСЃС– РјС–СЃС‚Р°"}</span></div>
                <span>{new Date(item.startedAt).toLocaleString("uk-UA")}</span>
                <span className={`status-badge ${String(item.status || "").toLowerCase()}`}>{item.status}</span>
                <div className="import-result"><strong>{item.publishedCount} РѕРїСѓР±Р»С–РєРѕРІР°РЅРѕ</strong><span>{item.reviewCount} РЅР° РїРµСЂРµРІС–СЂС†С–, {item.rejectedCount} РІС–РґС…РёР»РµРЅРѕ</span></div>
              </div>
            ))}
          </div>
        </div>
      )}
      {tab === "review" && (
        <div className="review-grid">
          {reviewListings.length === 0 ? (
            <div className="empty-state">
              <ShieldCheck size={38} />
              <h2>Р§РµСЂРіР° РјРѕРґРµСЂР°С†С–С— РїРѕСЂРѕР¶РЅСЏ</h2>
              <p>РџС–СЃР»СЏ С–РјРїРѕСЂС‚Сѓ С‚СѓС‚ Р·'СЏРІР»СЏС‚СЊСЃСЏ РѕРіРѕР»РѕС€РµРЅРЅСЏ, СЏРєС– СЃРёСЃС‚РµРјР° РЅРµ Р·РјРѕРіР»Р° СЃС…РІР°Р»РёС‚Рё Р°РІС‚РѕРјР°С‚РёС‡РЅРѕ.</p>
            </div>
          ) : (
            reviewListings.map((item) => (
              <article className="review-card review-preview-card" key={item.id} onClick={() => onOpenReview(item)}>
                <div className="review-card-image">
                  <img src={apartmentPreviewImage(item)} alt={item.title} onError={(event) => { event.currentTarget.src = apartmentPreviewImage({ ...item, imageUrl: "" }); }} />
                </div>
                <div className="review-card-head">
                  <div><strong>{item.title}</strong><span>{item.city}, {item.district}</span></div>
                  <span className="status-badge pending">РџРѕС‚СЂРµР±СѓС” СЂС–С€РµРЅРЅСЏ</span>
                </div>
                <div className="review-card-meta">
                  <span>{formatPrice(item.price, item.currency)}</span>
                  <span>{item.rooms} РєС–РјРЅ. вЂў {item.area} Рј2 вЂў {item.floor}/{item.totalFloors} РїРѕРІРµСЂС…</span>
                  <span>РќР°РґС–Р№РЅС–СЃС‚СЊ {item.trustScore}/100</span>
                  <span>Р’РёРіС–РґРЅС–СЃС‚СЊ {item.valueScore}/100</span>
                </div>
                <p className="review-card-description">{shortText(item.description, 220)}</p>
                <div className="review-card-actions">
                  <button className="approve-button wide" onClick={() => void onReviewStatus(item.id, "PUBLISHED")}><Check size={18} /> РћРїСѓР±Р»С–РєСѓРІР°С‚Рё</button>
                  <button className="reject-button wide" onClick={() => void onReviewStatus(item.id, "REJECTED")}><X size={18} /> Р’С–РґС…РёР»РёС‚Рё</button>
                </div>
              </article>
            ))
          )}
        </div>
      )}
    </main>
  );
}

export default function App() {
  const [filters, setFilters] = useState<SearchFilters>({ city: "", maxPrice: "", rooms: "", currency: "", withoutBroker: "" });
  const [apartments, setApartments] = useState<Apartment[]>([]);
  const [stats, setStats] = useState({ totalListings: 0, verifiedListings: 0, averageSavings: 0, supportedCities: 0 });
  const [selectedApartment, setSelectedApartment] = useState<Apartment | null>(null);
  const [user, setUser] = useState<UserSummary | null>(null);
  const [favorites, setFavorites] = useState<Apartment[]>([]);
  const [adminUsers, setAdminUsers] = useState<UserSummary[]>([]);
  const [adminSources, setAdminSources] = useState<DataSource[]>([]);
  const [adminImports, setAdminImports] = useState<ImportRun[]>([]);
  const [reviewListings, setReviewListings] = useState<Apartment[]>([]);
  const [adminTab, setAdminTab] = useState<"users" | "sources" | "review">("users");
  const [detailState, setDetailState] = useState<{
    apartment: Apartment;
    mode: "catalog" | "review";
    origin: "search" | "favorites" | "admin";
  } | null>(null);
  const [activeView, setActiveView] = useState<"search" | "favorites" | "account" | "admin">("search");
  const [authMode, setAuthMode] = useState<"login" | "register" | null>(null);
  const [isLoading, setIsLoading] = useState(false);
  const [catalogMessage, setCatalogMessage] = useState("");

  const isApprovedUser = user?.role === "USER" && user.status === "APPROVED";
  const isAdmin = user?.role === "ADMIN";
  const favoriteIds = useMemo(() => new Set(favorites.map((item) => item.id)), [favorites]);

  useEffect(() => {
    void getStats()
      .then((result) => setStats(result.data))
      .catch(() => setCatalogMessage("РќРµ РІРґР°Р»РѕСЃСЏ Р·Р°РІР°РЅС‚Р°Р¶РёС‚Рё СЃС‚Р°С‚РёСЃС‚РёРєСѓ Р· Р±РµРєРµРЅРґСѓ."));
    void getApartments({})
      .then((result) => {
        setApartments(result.data);
        setSelectedApartment(result.data[0] || null);
        setCatalogMessage(result.data.length ? "" : "РЈ РєР°С‚Р°Р»РѕР·С– С‰Рµ РЅРµРјР°С” РѕРїСѓР±Р»С–РєРѕРІР°РЅРёС… РєРІР°СЂС‚РёСЂ. Р—Р°РїСѓСЃС‚Рё СЃРёРЅС…СЂРѕРЅС–Р·Р°С†С–СЋ РІ Р°РґРјС–РЅС†С–, С‰РѕР± РїС–РґС‚СЏРіРЅСѓС‚Рё СЂРµР°Р»СЊРЅС– РѕРіРѕР»РѕС€РµРЅРЅСЏ.");
      })
      .catch(() => setCatalogMessage("РќРµ РІРґР°Р»РѕСЃСЏ Р·Р°РІР°РЅС‚Р°Р¶РёС‚Рё РєРІР°СЂС‚РёСЂРё Р· Р±РµРєРµРЅРґСѓ. РџРµСЂРµРІС–СЂ, С‡Рё Spring-СЃРµСЂРІРµСЂ Р·Р°РїСѓС‰РµРЅРёР№ С– С‡Рё `VITE_API_URL` РІРєР°Р·СѓС” РЅР° РЅСЊРѕРіРѕ."));

    if (localStorage.getItem("homesafe_token")) {
      void getCurrentUser().then((result) => handleAuthenticatedUser(result.data)).catch(() => localStorage.removeItem("homesafe_token"));
    }
  }, []);

  async function loadAdminData() {
    const [usersResult, sourcesResult, importsResult, reviewResult] = await Promise.all([
      getAdminUsers(),
      getAdminSources(),
      getAdminImports(),
      getAdminReviewListings()
    ]);
    setAdminUsers(usersResult.data);
    setAdminSources(sourcesResult.data);
    setAdminImports(importsResult.data);
    setReviewListings(reviewResult.data);
  }

  async function handleAuthenticatedUser(nextUser: UserSummary) {
    setUser(nextUser);
    if (nextUser.status !== "APPROVED") return;
    if (nextUser.role === "ADMIN") {
      await loadAdminData();
      setActiveView("admin");
      return;
    }
    const result = await getFavorites();
    setFavorites(result.data);
  }

  async function handleSearch(event: FormEvent<HTMLFormElement>) {
    event.preventDefault();
    setIsLoading(true);
    try {
      const result = await getApartments(filters);
      setApartments(result.data);
      setSelectedApartment(result.data[0] || null);
      setCatalogMessage(result.data.length ? "" : "Р—Р° С†РёРјРё С„С–Р»СЊС‚СЂР°РјРё СЂРµР°Р»СЊРЅРёС… РєРІР°СЂС‚РёСЂ РїРѕРєРё РЅРµ Р·РЅР°Р№РґРµРЅРѕ.");
    } catch (error) {
      setCatalogMessage(getErrorMessage(error));
    } finally {
      setIsLoading(false);
    }
  }

  async function handleFavorite(apartment: Apartment) {
    if (!user) {
      setAuthMode("login");
      return;
    }
    if (!isApprovedUser) {
      setActiveView("account");
      return;
    }
    if (favoriteIds.has(apartment.id)) {
      await removeFavorite(apartment.id);
      setFavorites((items) => items.filter((item) => item.id !== apartment.id));
    } else {
      await addFavorite(apartment.id);
      setFavorites((items) => [apartment, ...items]);
    }
  }

  async function handleLogout() {
    try {
      await logoutUser();
    } catch {
      // Local session cleanup is enough here.
    }
    localStorage.removeItem("homesafe_token");
    setUser(null);
    setFavorites([]);
    setAdminUsers([]);
    setAdminSources([]);
    setAdminImports([]);
    setReviewListings([]);
    setDetailState(null);
    setActiveView("search");
  }

  async function handleStatusChange(userId: string, status: string) {
    const result = await updateUserStatus(userId, status);
    setAdminUsers((items) => items.map((item) => item.id === userId ? result.data : item));
  }

  async function handleSourceToggle(source: DataSource) {
    const result = await updateAdminSource(source.code, { enabled: !source.enabled });
    setAdminSources((items) => items.map((item) => item.code === source.code ? result.data : item));
  }

  async function handleRunSync(code: string) {
    const source = adminSources.find((item) => item.code === code);
    const payload = code === "DIM_RIA"
      ? { ...(source?.config?.syncDefaults || {}) }
      : { ...(source?.config?.syncDefaults || {}), offset: source?.config?.syncDefaults?.offset ?? 0 };
    try {
      await runAdminSync(code, payload);
      await loadAdminData();
    } catch (error) {
      setAdminSources((items) => items.map((item) => (
        item.code === code
          ? { ...item, lastStatus: "FAILED", lastError: getErrorMessage(error), enabled: source?.enabled ?? item.enabled }
          : item
      )));
    }
  }

  async function handleReviewStatus(apartmentId: string, status: string) {
    await updateAdminListingStatus(apartmentId, status);
    setReviewListings((items) => items.filter((item) => item.id !== apartmentId));
    setDetailState(null);
    if (status === "PUBLISHED") {
      const result = await getApartments(filters);
      setApartments(result.data);
      setCatalogMessage(result.data.length ? "" : "РЈ РєР°С‚Р°Р»РѕР·С– С‰Рµ РЅРµРјР°С” РѕРїСѓР±Р»С–РєРѕРІР°РЅРёС… РєРІР°СЂС‚РёСЂ.");
      const publishedApartment = result.data.find((item) => item.id === apartmentId);
      setSelectedApartment(publishedApartment || result.data[0] || null);
      setActiveView("search");
      return;
    }
    setActiveView("admin");
  }

  function openApartment(apartment: Apartment) {
    setSelectedApartment(apartment);
    setDetailState({ apartment, mode: "catalog", origin: activeView === "favorites" ? "favorites" : "search" });
  }

  function openReviewApartment(apartment: Apartment) {
    setAdminTab("review");
    setDetailState({ apartment, mode: "review", origin: "admin" });
  }

  function closeDetail() {
    setDetailState(null);
  }

  if (user && user.status !== "APPROVED") {
    return <PendingAccount user={user} onLogout={handleLogout} />;
  }

  return (
    <div className="app-shell">
      <header className="topbar">
        <button className="brand brand-button" onClick={() => setActiveView("search")} aria-label="HomeSafe">
          <span><ShieldCheck size={24} /></span>HomeSafe
        </button>
        <nav className="nav-links" aria-label="РћСЃРЅРѕРІРЅР° РЅР°РІС–РіР°С†С–СЏ">
          <button onClick={() => setActiveView("search")}>РљРІР°СЂС‚РёСЂРё</button>
          {isApprovedUser && <button onClick={() => setActiveView("favorites")}>РћР±СЂР°РЅРµ ({favorites.length})</button>}
          {isApprovedUser && <button onClick={() => setActiveView("account")}>РњС–Р№ РєР°Р±С–РЅРµС‚</button>}
          {isAdmin && <button onClick={() => setActiveView("admin")}>РђРґРјС–РЅС–СЃС‚СЂР°С‚РѕСЂ</button>}
        </nav>
        <div className="topbar-actions">
          {!user ? (
            <>
              <button className="text-button" onClick={() => setAuthMode("login")}>РЈРІС–Р№С‚Рё</button>
              <button className="primary-button compact" onClick={() => setAuthMode("register")}>Р РµС”СЃС‚СЂР°С†С–СЏ</button>
            </>
          ) : (
            <>
              <span className="user-chip"><UserRound size={17} /> {user.name}</span>
              <button className="icon-button" onClick={() => void handleLogout()} aria-label="Р’РёР№С‚Рё"><LogOut size={19} /></button>
            </>
          )}
        </div>
      </header>
      {activeView === "favorites" && <FavoritesPage favorites={favorites} onSelect={openApartment} onRemove={handleFavorite} />}
      {activeView === "account" && user && <UserAccount user={user} favorites={favorites} />}
      {activeView === "admin" && (
        <AdminConsolePage
          users={adminUsers}
          sources={adminSources}
          imports={adminImports}
          reviewListings={reviewListings}
          tab={adminTab}
          onTabChange={setAdminTab}
          onStatusChange={handleStatusChange}
          onSourceToggle={handleSourceToggle}
          onRunSync={handleRunSync}
          onReviewStatus={handleReviewStatus}
          onOpenReview={openReviewApartment}
        />
      )}
      {activeView === "search" && (
        <main id="top">
          <section className="hero-section">
            <div className="hero-copy">
              <span className="eyebrow">Р–РёС‚Р»Рѕ Р±РµР· РїРѕСЃРµСЂРµРґРЅРёРєС–РІ РґР»СЏ Р’РџРћ С‚Р° Р±С–Р¶РµРЅС†С–РІ</span>
              <h1>Р—РЅР°Р№РґС–С‚СЊ Р±РµР·РїРµС‡РЅСѓ РєРІР°СЂС‚РёСЂСѓ Р· РїРѕСЏСЃРЅРµРЅРЅСЏРј, С‡РѕРјСѓ РІРѕРЅР° РІРёРіС–РґРЅР°</h1>
              <p>HomeSafe РїРµСЂРµРІС–СЂСЏС” СЂРёР·РёРєРё С€Р°С…СЂР°Р№СЃС‚РІР°, РїРѕСЂС–РІРЅСЋС” С†С–РЅРё С‚Р° РїРѕРєР°Р·СѓС” РЅР°Р№РєСЂР°С‰С– РІР°СЂС–Р°РЅС‚Рё РґР»СЏ СЂРµР°Р»СЊРЅРѕРіРѕ Р¶РёС‚С‚СЏ.</p>
            </div>
            <form className="search-panel" onSubmit={handleSearch}>
              <label>РњС–СЃС‚Рѕ<input value={filters.city} onChange={(event) => setFilters({ ...filters, city: event.target.value })} placeholder="РљРёС—РІ, Р›СЊРІС–РІ, Р”РЅС–РїСЂРѕ" /></label>
              <label>Р‘СЋРґР¶РµС‚ РґРѕ<input type="number" value={filters.maxPrice} onChange={(event) => setFilters({ ...filters, maxPrice: event.target.value })} placeholder="15000" /></label>
              <label>РљС–РјРЅР°С‚<select value={filters.rooms} onChange={(event) => setFilters({ ...filters, rooms: event.target.value })}><option value="">Р‘СѓРґСЊ-СЏРєР°</option><option value="1">1</option><option value="2">2</option><option value="3">3+</option></select></label>
              <label>Р’Р°Р»СЋС‚Р°<select value={filters.currency} onChange={(event) => setFilters({ ...filters, currency: event.target.value })}><option value="">РЈСЃС– РІР°Р»СЋС‚Рё</option><option value="UAH">Р“СЂРёРІРЅСЏ</option><option value="USD">Р”РѕР»Р°СЂ РЎРЁРђ</option><option value="EUR">Р„РІСЂРѕ</option></select></label>
              <label>РўРёРї РѕРіРѕР»РѕС€РµРЅРЅСЏ<select value={filters.withoutBroker} onChange={(event) => setFilters({ ...filters, withoutBroker: event.target.value })}><option value="">РЈСЃС– РѕРіРѕР»РѕС€РµРЅРЅСЏ</option><option value="true">Р›РёС€Рµ Р±РµР· РїРѕСЃРµСЂРµРґРЅРёРєС–РІ</option><option value="false">РџРѕС‚СЂС–Р±РЅР° РїРµСЂРµРІС–СЂРєР° РІР»Р°СЃРЅРёРєР°</option></select></label>
              <button type="submit"><Search size={19} />{isLoading ? "РЁСѓРєР°С”РјРѕ..." : "Р—РЅР°Р№С‚Рё Р¶РёС‚Р»Рѕ"}</button>
            </form>
          </section>
          <section className="stats-section">
            <StatCard icon={Building2} label="РѕРіРѕР»РѕС€РµРЅСЊ Сѓ СЃРёСЃС‚РµРјС–" value={currency.format(stats.totalListings)} />
            <StatCard icon={ShieldCheck} label="РїРµСЂРµРІС–СЂРµРЅРёС… РєРІР°СЂС‚РёСЂ" value={currency.format(stats.verifiedListings)} />
            <StatCard icon={SlidersHorizontal} label="СЃРµСЂРµРґРЅСЏ РµРєРѕРЅРѕРјС–СЏ" value={`${stats.averageSavings}%`} />
            <StatCard icon={Train} label="РјС–СЃС‚ РїС–РґС‚СЂРёРјСѓС”С‚СЊСЃСЏ" value={stats.supportedCities} />
          </section>
          <section className="workspace-section" id="apartments">
            <div className="section-heading">
              <div><span className="eyebrow">Р РµРєРѕРјРµРЅРґРѕРІР°РЅС– РІР°СЂС–Р°РЅС‚Рё</span><h2>РљРІР°СЂС‚РёСЂРё, РІС–РґСЃРѕСЂС‚РѕРІР°РЅС– Р·Р° РґРѕРІС–СЂРѕСЋ С‚Р° РІРёРіС–РґРЅС–СЃС‚СЋ</h2></div>
              {!user && <button className="secondary-button" onClick={() => setAuthMode("register")}><UserRound size={18} /> РЎС‚РІРѕСЂРёС‚Рё РєР°Р±С–РЅРµС‚</button>}
            </div>
            <div className="content-grid">
              <div className="apartment-list">
                {catalogMessage && apartments.length === 0 ? (
                  <div className="empty-state">
                    <Home size={38} />
                    <h2>Р РµР°Р»СЊРЅРёС… РєРІР°СЂС‚РёСЂ РїРѕРєРё РЅРµРјР°С”</h2>
                    <p>{catalogMessage}</p>
                  </div>
                ) : (
                  apartments.map((apartment) => (
                    <ApartmentCard
                      key={apartment.id}
                      apartment={apartment}
                      selected={selectedApartment?.id === apartment.id}
                      onSelect={openApartment}
                      isFavorite={favoriteIds.has(apartment.id)}
                      onFavorite={handleFavorite}
                    />
                  ))
                )}
              </div>
              <DetailsPanel apartment={selectedApartment} />
            </div>
          </section>
        </main>
      )}
      {authMode && <AuthModal initialMode={authMode} onClose={() => setAuthMode(null)} onLogin={handleAuthenticatedUser} />}
      {detailState && (
        <div className="detail-overlay">
          <ApartmentDetailPage
            apartment={detailState.apartment}
            mode={detailState.mode}
            isFavorite={favoriteIds.has(detailState.apartment.id)}
            onBack={closeDetail}
            onFavorite={handleFavorite}
            onReviewStatus={handleReviewStatus}
          />
        </div>
      )}
    </div>
  );
}
